proxy-groups:

  # 美国 AI 节点池
  - name: AI-US
    type: url-test

    # 导入所有节点
    include-all: true

    # 自动筛选美国节点
    filter: "(?i)US|America|United States|美国|Los|纽约|硅谷|San Jose|Seattle"

    # 测速地址
    url: http://www.gstatic.com/generate_204

    # 每5分钟测速
    interval: 300

    # 延迟容差
    tolerance: 50

rules:

  # Gemini
  - DOMAIN,gemini.google.com,AI-US
  - DOMAIN,aistudio.google.com,AI-US
  - DOMAIN,generativelanguage.googleapis.com,AI-US

  # OpenAI
  - DOMAIN-SUFFIX,openai.com,AI-US
  - DOMAIN-SUFFIX,chatgpt.com,AI-US
  - DOMAIN,ios.chat.openai.com,AI-US

  # Claude
  - DOMAIN-SUFFIX,anthropic.com,AI-US
  - DOMAIN-SUFFIX,claude.ai,AI-US

  # Google API
  - DOMAIN-SUFFIX,googleapis.com,AI-US
  - DOMAIN-SUFFIX,gstatic.com,AI-US
  - DOMAIN-SUFFIX,googleusercontent.com,AI-US
  - DOMAIN-SUFFIX,google.com,AI-US
