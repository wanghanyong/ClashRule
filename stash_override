proxy-groups:

  # =========================
  # 美国 AI 节点池
  # 自动测速选最快美国节点
  # =========================
  - name: AI-US
    type: url-test

    # 导入所有节点
    include-all-proxies: true

    # 自动筛选美国节点
    filter: "(?i)US|America|United States|美国|Los|纽约|硅谷|San Jose|Seattle"

    # 测速地址
    url: http://www.gstatic.com/generate_204

    # 每5分钟测速
    interval: 300

    # 延迟容差
    tolerance: 50

rules:

  # =========================
  # Gemini
  # =========================
  - DOMAIN,gemini.google.com,AI
  - DOMAIN,aistudio.google.com,AI
  - DOMAIN,generativelanguage.googleapis.com,AI

  # =========================
  # OpenAI / ChatGPT
  # =========================
  - DOMAIN-SUFFIX,openai.com,AI
  - DOMAIN-SUFFIX,chatgpt.com,AI
  - DOMAIN,ios.chat.openai.com,AI

  # =========================
  # Claude
  # =========================
  - DOMAIN-SUFFIX,anthropic.com,AI
  - DOMAIN-SUFFIX,claude.ai,AI

  # =========================
  # Google API
  # =========================
  - DOMAIN-SUFFIX,googleapis.com,AI
  - DOMAIN-SUFFIX,gstatic.com,AI
  - DOMAIN-SUFFIX,googleusercontent.com,AI
  - DOMAIN-SUFFIX,google.com,AI
